local fallback = 'en'

local function getLocale(): string
  local locale = game:GetService('LocalizationService').RobloxLocaleId
  if strings[locale] then
    return locale
  end
  local short = locale:sub(1, 2)
  if strings[short] then
    return short
  end
  return fallback
end

function Localization.get(key: string): string
  local locale = getLocale()
  local localeStrings = strings[locale] or strings[fallback]
  return localeStrings[key] or strings[fallback][key] or key
end

return Localization
